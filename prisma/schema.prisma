generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String?
  name      String?
  googleId  String?  @unique
  avatar    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  images Image[]
  orders Order[]
}

model Image {
  id           String   @id @default(uuid())
  userId       String
  originalUrl  String
  generatedUrl String?
  style        String
  status       String   @default("pending")
  prompt       String?
  createdAt    DateTime @default(now())

  user   User    @relation(fields: [userId], references: [id])
  orders Order[]
}

model Order {
  id          String   @id @default(uuid())
  userId      String
  imageId     String
  productType String
  size        String   @default("16x20")
  price       Float
  status      String   @default("pending")
  printfulId  String?
  stripeId    String?
  shippingName     String?
  shippingAddress  String?
  shippingAddress2 String?
  shippingCity     String?
  shippingState    String?
  shippingZip      String?
  shippingCountry  String?
  shippingPhone    String?
  shippingMethod   String?  @default("STANDARD")
  trackingNumber   String?
  trackingUrl      String?
  frameColor           String?  @default("black")
  digitalCopy          Boolean  @default(false)
  extraCopy            Boolean  @default(false)
  refundReason         String?
  refundRequestedAt    DateTime?
  refundEvidenceUrl    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user  User  @relation(fields: [userId], references: [id])
  image Image @relation(fields: [imageId], references: [id])
}

model Email {
  id        String   @id @default(uuid())
  direction String   // 'sent' | 'received'
  from      String
  to        String
  subject   String
  body      String   @db.Text
  orderId   String?
  read      Boolean  @default(false)
  resendId  String?
  createdAt DateTime @default(now())

  @@index([direction])
  @@index([createdAt])
}

model Config {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

model Log {
  id        String   @id @default(uuid())
  level     String   // 'info' | 'warn' | 'error'
  source    String   // e.g. 'fulfillment', 'webhook', 'generate', 'confirm'
  message   String
  meta      String?  // JSON string for extra context
  createdAt DateTime @default(now())

  @@index([level])
  @@index([createdAt])
}
